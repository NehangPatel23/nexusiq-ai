# dependencies
node_modules/
.pnp
.pnp.js
.pnpm-store/

# build
.next/
.next*/
out/
dist/
build/
.turbo/

# misc caches
.cache/
.vitest/

# supabase CLI local state (if you run `supabase init` later)
supabase/.branches
supabase/.temp

# docker bind-mount data (compose uses named volume; ignore if you switch to ./pgdata)
pgdata/

# env & secrets (never commit real credentials)
.env
.env.*
!.env.example

# debug
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# testing
coverage/
playwright-report/
blob-report/
test-results/
playwright/.cache/

# storage & uploads (local avatars/documents)
storage/

# local DB exports (use pnpm db:sync-to-supabase instead)
local_data.sql
*.sql.dump

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
*.pem
.vercel
*.tsbuildinfo

# next.js generated (regenerated by `next dev` / `next build`)
next-env.d.ts

# cursor (keep project rules, ignore local IDE state)
.cursor/**
!.cursor/rules/
!.cursor/rules/**
