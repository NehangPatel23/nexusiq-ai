# Database
# Local dev (Docker):
DATABASE_URL="postgresql://nexusiq:nexusiq@localhost:5433/nexusiq?schema=public"

# Production (Supabase) — see docs/deployment.md for Connect panel steps
# Migrations (Session pooler, port 5432):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
# Vercel runtime (Transaction pooler, port 6543):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# One-way data sync: local Docker → Supabase (Session pooler, port 5432 — for scripts only)
# SUPABASE_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Auth (slice 01-auth)
AUTH_SECRET="change-me-to-a-random-32-char-secret"
# Generate for production: openssl rand -base64 32

# Supabase (production / hackathon — Storage + optional client features)
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://irnijvkmacxtttopcrfa.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlybmlqdmttYWN4dHR0b3BjcmZhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1MzMwMjUsImV4cCI6MjA5OTEwOTAyNX0.NXvQN5TBZIf1d87E4FimdYCPjQpo47IIOkcZJLyPvIk"
# Server only — never expose to browser or commit
SUPABASE_SERVICE_ROLE_KEY="SECRET_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET_DOCUMENTS="documents"
SUPABASE_STORAGE_BUCKET_AVATARS="avatars"

# Ollama — one client for local dev, Vercel prod, and worker VPS (see docs/deployment.md)
# Local dev (Mac):
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="llama3"
OLLAMA_EMBED_MODEL="nomic-embed-text"
ENABLE_INLINE_PROCESSING="true"
WORKER_POLL_INTERVAL_MS="5000"
WORKER_CONCURRENCY="1"

# Vercel prod (public HTTPS Ollama + API key):
# OLLAMA_BASE_URL="https://ollama.yourdomain.com"
# OLLAMA_API_KEY="your-secret"
# ENABLE_INLINE_PROCESSING="false"

# Worker VPS (Ollama on same machine) — production: see tasks/00-oci-worker-vps.md (OCI, deferred)
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
# ENABLE_INLINE_PROCESSING="false"
# WORKER_POLL_INTERVAL_MS="5000"
# WORKER_CONCURRENCY="1"

# App
# Production: set to your Vercel URL (required for invite/reset links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Data room — auto-purge soft-deleted items after N days (default 30)
DATA_ROOM_DELETED_RETENTION_DAYS="30"

# Search — relevance thresholds (optional tuning)
# SEARCH_KEYWORD_MIN_RANK="0.01"
# SEARCH_SEMANTIC_MIN_SCORE="0.48"

# Storage (local dev only; use Supabase Storage on Vercel — see docs/deployment.md)
STORAGE_PATH="./storage"
