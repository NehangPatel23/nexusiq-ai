generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum OrgRole {
  OWNER
  ADMIN
  ANALYST
  REVIEWER
  VIEWER
}

enum NotificationType {
  PROCESSING_COMPLETE
  RISK_FOUND
  TASK_ASSIGNED
  MENTION
  SYSTEM
}

enum ProjectType {
  MA
  VENDOR_DD
  AUDIT
  INVESTMENT
  INTERNAL
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum DocumentType {
  PDF
  DOCX
  XLSX
  CSV
  PPTX
  TXT
  MD
  IMAGE
  OTHER
}

enum DocumentClassification {
  FINANCIAL
  LEGAL
  TAX
  HR
  OPERATIONAL
  COMPLIANCE
  CONTRACT
  CORRESPONDENCE
  OTHER
}

enum DataRoomAuditAction {
  UPLOADED
  SOFT_DELETED
  RESTORED
  PERMANENTLY_DELETED
  REPROCESSED
  RENAMED
  MOVED
  SHARE_CREATED
  SHARE_REVOKED
  AGENT_RUN_COMPLETED
  AGENT_RUN_FAILED
  REPORT_GENERATED
  REPORT_EXPORTED
  REPORT_SHARE_CREATED
  REPORT_SHARE_REVOKED
}

enum DataRoomResourceType {
  DOCUMENT
  FOLDER
  PROJECT
  REPORT
}

enum SearchMode {
  HYBRID
  SEMANTIC
  KEYWORD
}

enum ChatAgentType {
  GENERAL
  FINANCIAL
  LEGAL
  COMPLIANCE
  RISK
  FRAUD
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
  INSUFFICIENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum AgentType {
  FINANCIAL
  LEGAL
  COMPLIANCE
  RISK
  FRAUD
  EXECUTIVE
}

enum AgentRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum RiskStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
  SUPERSEDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  UPLOAD
  PROCESS
  SEARCH
  CHAT
  REPORT
  AGENT_RUN
  CONSENSUS
  SIMULATION
  USER_DELETED
  USER_RECOVERED
  USER_PURGED
  ORG_DELETED
  ORG_RECOVERED
  ORG_PURGED
  SETTINGS_UPDATE
  MAINTENANCE
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ContradictionStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum ContradictionFactType {
  DATE
  AMOUNT
  PARTY
  METRIC
  OTHER
}

enum MissingItemStatus {
  OPEN
  REQUESTED
  RESOLVED
  NOT_APPLICABLE
}

enum ReportType {
  EXECUTIVE
  BOARD
  INVESTMENT_MEMO
  AUDIT
  RISK_REGISTER
  ACTION_PLAN
  PPTX
}

enum ReportFormat {
  MARKDOWN
  PDF
  XLSX
  PPTX
}

enum TimelineCategory {
  FUNDING
  HIRING
  ACQUISITION
  LAWSUIT
  LEADERSHIP
  REVENUE
  CONTRACT
  OTHER
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String?
  passwordHash      String    @map("password_hash")
  image             String?
  theme             String    @default("dark")
  notificationPrefs Json?     @map("notification_prefs")
  emailVerified     DateTime? @map("email_verified")
  deletedAt         DateTime? @map("deleted_at")
  purgeAfter        DateTime? @map("purge_after")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  passwordResetTokens PasswordResetToken[]
  organizationMembers OrganizationMember[]
  teamMembers         TeamMember[]
  notifications       Notification[]
  documentVersions    DocumentVersion[]
  dataRoomAuditEvents DataRoomAuditEvent[]
  dataRoomShares      DataRoomShare[]
  reportShares        ReportShare[]
  savedSearches       SavedSearch[]
  chats               Chat[]
  agentRuns           AgentRun[]
  consensusRuns       ConsensusRun[]
  reports             Report[]
  simulationRuns      SimulationRun[]
  assignedTasks       Task[]           @relation("TaskAssignee")
  auditLogs           AuditLog[]

  @@index([deletedAt])
  @@index([purgeAfter])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [email], references: [email], onDelete: Cascade)

  @@index([email])
  @@map("password_reset_tokens")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?   @map("logo_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  purgeAfter  DateTime? @map("purge_after")

  members    OrganizationMember[]
  teams      Team[]
  invites    Invite[]
  workspaces Workspace[]
  auditLogs  AuditLog[]

  @@index([purgeAfter])
  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Team {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  workspaces   Workspace[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Invite {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String
  role           OrgRole
  token          String    @unique
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@map("invites")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  type       NotificationType
  title      String
  body       String
  link       String?
  readAt     DateTime?        @map("read_at")
  archivedAt DateTime?        @map("archived_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, archivedAt])
  @@map("notifications")
}

model Workspace {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  slug           String
  description    String?
  teamId         String?   @map("team_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  projects     Project[]

  @@unique([organizationId, slug])
  @@index([organizationId, deletedAt])
  @@map("workspaces")
}

model Project {
  id            String      @id @default(uuid())
  workspaceId   String      @map("workspace_id")
  name          String
  slug          String
  description   String?
  type          ProjectType
  targetCompany String?     @map("target_company")
  dealStatus    String?     @map("deal_status")
  tags          String[]
  metadata      Json?
  pinned        Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folders         Folder[]
  documents       Document[]
  auditEvents     DataRoomAuditEvent[]
  shares          DataRoomShare[]
  entities        Entity[]
  entityRelations EntityRelation[]
  savedSearches   SavedSearch[]
  chats           Chat[]
  agentRuns       AgentRun[]
  consensusRuns   ConsensusRun[]
  findings        Finding[]
  contradictions  Contradiction[]
  missingItems    MissingItem[]
  reports         Report[]
  reportShares    ReportShare[]
  timelineEvents  TimelineEvent[]
  simulationRuns  SimulationRun[]
  tasks           Task[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, deletedAt])
  @@map("projects")
}

model Folder {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  parentId  String?   @map("parent_id")
  name      String
  path      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderTree")
  documents Document[]

  @@index([projectId, deletedAt])
  @@index([parentId])
  @@map("folders")
}

model Document {
  id                String                  @id @default(uuid())
  projectId         String                  @map("project_id")
  folderId          String?                 @map("folder_id")
  name              String
  originalName      String                  @map("original_name")
  mimeType          String                  @map("mime_type")
  type              DocumentType
  classification    DocumentClassification?
  filePath          String                  @map("file_path")
  fileSize          Int                     @map("file_size")
  pageCount         Int?                    @map("page_count")
  status            DocumentStatus          @default(PENDING)
  version           Int                     @default(1)
  previousVersionId String?                 @map("previous_version_id")
  contentHash       String?                 @map("content_hash")
  duplicateOfId     String?                 @map("duplicate_of_id")
  tags              String[]
  errorMessage      String?                 @map("error_message")
  processedAt       DateTime?               @map("processed_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  deletedAt         DateTime?               @map("deleted_at")

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder          Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  previousVersion Document?         @relation("DocumentVersions", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions    Document[]        @relation("DocumentVersions")
  duplicateOf     Document?         @relation("DocumentDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates      Document[]        @relation("DocumentDuplicates")
  versions             DocumentVersion[]
  chunks               DocumentChunk[]
  timelineEvents       TimelineEvent[]
  contradictionsAsDocA Contradiction[]   @relation("ContradictionDocA")
  contradictionsAsDocB Contradiction[]   @relation("ContradictionDocB")
  tasks                Task[]

  @@index([projectId, folderId, deletedAt])
  @@index([projectId, deletedAt])
  @@index([status])
  @@map("documents")
}

model DocumentVersion {
  id           String   @id @default(uuid())
  documentId   String   @map("document_id")
  version      Int
  filePath     String   @map("file_path")
  fileSize     Int      @map("file_size")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
  @@index([uploadedById])
  @@map("document_versions")
}

model DataRoomAuditEvent {
  id           String               @id @default(uuid())
  projectId    String               @map("project_id")
  actorId      String?              @map("actor_id")
  action       DataRoomAuditAction
  resourceType DataRoomResourceType @map("resource_type")
  resourceId   String               @map("resource_id")
  resourceName String               @map("resource_name")
  metadata     Json?
  createdAt    DateTime             @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("data_room_audit_events")
}

model DataRoomShare {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  token       String    @unique
  label       String?
  expiresAt   DateTime? @map("expires_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("data_room_shares")
}

model DocumentChunk {
  id           String                      @id @default(uuid())
  documentId   String                      @map("document_id")
  chunkIndex   Int                         @map("chunk_index")
  content      String
  tokenCount   Int                         @map("token_count")
  embedding    Unsupported("vector(768)")?
  searchVector Unsupported("tsvector")?    @map("search_vector")
  pageNumber   Int?                        @map("page_number")
  sectionTitle String?                     @map("section_title")
  metadata     Json?
  createdAt    DateTime                    @default(now()) @map("created_at")

  document          Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sourceRelations   EntityRelation[] @relation("SourceChunk")
  timelineEvents    TimelineEvent[]

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("document_chunks")
}

model TimelineEvent {
  id            String           @id @default(uuid())
  projectId     String           @map("project_id")
  title         String
  description   String?
  eventDate     DateTime         @map("event_date")
  category      TimelineCategory
  sourceChunkId String?          @map("source_chunk_id")
  documentId    String?          @map("document_id")
  isManual      Boolean          @default(false) @map("is_manual")
  pinned        Boolean          @default(false)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceChunk DocumentChunk?  @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)
  document    Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId, eventDate])
  @@index([projectId, deletedAt, eventDate])
  @@map("timeline_events")
}

model Entity {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  type      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceRelations EntityRelation[] @relation("SourceEntity")
  targetRelations EntityRelation[] @relation("TargetEntity")

  @@index([projectId, name, type])
  @@map("entities")
}

model EntityRelation {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  sourceEntityId String   @map("source_entity_id")
  targetEntityId String   @map("target_entity_id")
  relationType   String   @map("relation_type")
  confidence     Float
  sourceChunkId  String?  @map("source_chunk_id")
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEntity Entity         @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity Entity         @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)
  sourceChunk  DocumentChunk? @relation("SourceChunk", fields: [sourceChunkId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
  @@map("entity_relations")
}

model SavedSearch {
  id        String     @id @default(uuid())
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  name      String
  query     String
  filters   Json       @default("{}")
  mode      SearchMode @default(HYBRID)
  createdAt DateTime   @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("saved_searches")
}

model Chat {
  id        String        @id @default(uuid())
  projectId String        @map("project_id")
  userId    String        @map("user_id")
  title     String?
  agentType ChatAgentType @default(GENERAL) @map("agent_type")
  pinned    Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([projectId, userId, updatedAt])
  @@map("chats")
}

model ChatMessage {
  id               String           @id @default(uuid())
  chatId           String           @map("chat_id")
  role             ChatMessageRole
  content          String
  citations        Json?
  confidence       ConfidenceLevel?
  confidenceScore  Int?             @map("confidence_score")
  confidenceReason String?          @map("confidence_reason")
  createdAt        DateTime         @default(now()) @map("created_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("chat_messages")
}

model AgentRun {
  id            String           @id @default(uuid())
  projectId     String           @map("project_id")
  agentType     AgentType        @map("agent_type")
  status        AgentRunStatus   @default(PENDING)
  inputParams   Json?            @map("input_params")
  output        Json?
  score         Float?
  confidence    ConfidenceLevel?
  citations     Json?
  startedAt     DateTime         @default(now()) @map("started_at")
  completedAt   DateTime?        @map("completed_at")
  error         String?
  triggeredById String?          @map("triggered_by_id")

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User?     @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  findings    Finding[]

  @@index([projectId, agentType, startedAt])
  @@map("agent_runs")
}

model ConsensusRun {
  id                   String          @id @default(uuid())
  projectId            String          @map("project_id")
  agentRunIds          String[]        @map("agent_run_ids")
  finalRecommendation  String          @map("final_recommendation")
  decisionConfidence   ConfidenceLevel @map("decision_confidence")
  agreements           Json
  conflicts            Json
  resolutionRationale  String          @map("resolution_rationale")
  agentOpinions        Json            @map("agent_opinions")
  citations            Json?
  triggeredById        String?         @map("triggered_by_id")
  createdAt            DateTime        @default(now()) @map("created_at")

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User?   @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("consensus_runs")
}

model Finding {
  id            String           @id @default(uuid())
  projectId     String           @map("project_id")
  agentType     AgentType        @map("agent_type")
  agentRunId    String?          @map("agent_run_id")
  category      String
  title         String
  description   String
  severity      FindingSeverity?
  score         Float?
  sourceChunkId String?          @map("source_chunk_id")
  documentId    String?          @map("document_id")
  metadata      Json?
  status        RiskStatus       @default(OPEN)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentRun AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  tasks    Task[]

  @@index([projectId, agentType])
  @@index([agentRunId])
  @@map("findings")
}

model Contradiction {
  id                 String                 @id @default(uuid())
  projectId          String                 @map("project_id")
  subject            String
  factType           ContradictionFactType  @map("fact_type")
  valueA             String                 @map("value_a")
  valueB             String                 @map("value_b")
  documentAId        String                 @map("document_a_id")
  chunkAId           String                 @map("chunk_a_id")
  documentBId        String                 @map("document_b_id")
  chunkBId           String                 @map("chunk_b_id")
  explanation        String
  severity           FindingSeverity
  status             ContradictionStatus    @default(OPEN)
  resolutionNote     String?                @map("resolution_note")
  statusChangedById  String?                @map("status_changed_by_id")
  statusChangedAt    DateTime?              @map("status_changed_at")
  promotedFindingId  String?                @map("promoted_finding_id")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentA Document @relation("ContradictionDocA", fields: [documentAId], references: [id], onDelete: Cascade)
  documentB Document @relation("ContradictionDocB", fields: [documentBId], references: [id], onDelete: Cascade)

  @@index([projectId, status, severity])
  @@index([projectId, createdAt])
  @@index([chunkAId])
  @@index([chunkBId])
  @@map("contradictions")
}

model MissingItem {
  id           String            @id @default(uuid())
  projectId    String            @map("project_id")
  category     String
  title        String
  description  String
  expectedType String?           @map("expected_type")
  framework    String?
  followUpText String?           @map("follow_up_text")
  severity     FindingSeverity?
  status       MissingItemStatus @default(OPEN)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@map("missing_items")
}

model SimulationRun {
  id               String           @id @default(uuid())
  projectId        String           @map("project_id")
  scenarioName     String           @map("scenario_name")
  parameters       Json
  baselineScores   Json             @map("baseline_scores")
  simulatedScores  Json             @map("simulated_scores")
  delta            Json
  recommendation   String?
  keyImpacts       Json?            @map("key_impacts")
  confidence       ConfidenceLevel?
  baselineRunIds   String[]         @default([]) @map("baseline_run_ids")
  triggeredById    String?          @map("triggered_by_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User?   @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("simulation_runs")
}

model Task {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  title       String
  description String?
  assigneeId  String?      @map("assignee_id")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  impact      String?
  findingId   String?      @map("finding_id")
  documentId  String?      @map("document_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  finding  Finding? @relation(fields: [findingId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId, status, deletedAt])
  @@index([assigneeId])
  @@index([findingId])
  @@map("tasks")
}

model Report {
  id         String       @id @default(uuid())
  projectId  String       @map("project_id")
  userId     String       @map("user_id")
  title      String
  reportType ReportType   @map("report_type")
  content    String
  format     ReportFormat @default(MARKDOWN)
  filePath   String?      @map("file_path")
  metadata   Json?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares  ReportShare[]

  @@index([projectId, createdAt])
  @@index([userId])
  @@map("reports")
}

model ReportShare {
  id          String        @id @default(uuid())
  reportId    String        @map("report_id")
  projectId   String        @map("project_id")
  token       String        @unique
  label       String?
  format      ReportFormat?
  expiresAt   DateTime?     @map("expires_at")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  revokedAt   DateTime?     @map("revoked_at")

  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([projectId])
  @@map("report_shares")
}

model AuditLog {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  userId         String?     @map("user_id")
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String?     @map("entity_id")
  metadata       Json?
  ipAddress      String?     @map("ip_address")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([userId])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
